<Page x:Class="CipherVault.UI.Views.UnlockView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}"
      Title="Unlock - Cipher™ Vault">
    <Grid>
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="430" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="14" Padding="34">
            <StackPanel>
                <Border Height="4" CornerRadius="2" Background="{StaticResource AccentBrush}" Margin="0,0,0,18"/>

                <Border Width="56" Height="56" CornerRadius="12" Background="{StaticResource SurfaceHighBrush}"
                        HorizontalAlignment="Center" Margin="0,0,0,16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <Image Source="/Resources/app_clean.png" Width="40" Height="40" Stretch="Uniform"/>
                </Border>

                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,3">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Cipher" Style="{StaticResource BrandWordText}" FontSize="28"/>
                        <TextBlock Text="™" Style="{StaticResource BrandTrademarkText}" FontSize="12" Margin="-1,3,0,0"/>
                        <TextBlock Text=" Vault" Foreground="{StaticResource TextPrimaryBrush}" FontSize="28" FontWeight="SemiBold"/>
                    </StackPanel>
                    <Border Height="1" Width="92" HorizontalAlignment="Left" Margin="2,0,0,0"
                            Background="{StaticResource BrandUnderlineBrush}"/>
                </StackPanel>
                <TextBlock x:Name="SubtitleText" Text="Unlock your vault"
                           Style="{StaticResource SubHeading}" HorizontalAlignment="Center"
                           Margin="0,0,0,24"/>

                <Button x:Name="WindowsHelloBtn"
                        Style="{StaticResource PrimaryButton}"
                        Content="Continue with Windows (Hello/PIN/password)"
                        Height="44"
                        Margin="0,0,0,10"
                        Click="WindowsHelloBtn_Click"
                        Visibility="{Binding CanUseWindowsHello, Converter={StaticResource BoolToVisConverter}}"/>

                <TextBlock x:Name="ManualHintText"
                           Text="Or unlock manually with your master password"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           Margin="0,0,0,8"
                           Visibility="{Binding CanUseWindowsHello, Converter={StaticResource BoolToVisConverter}}"/>

                <Label Content="Master Password"/>
                <PasswordBox x:Name="PasswordInput" Margin="0,0,0,12"
                             KeyDown="PasswordInput_KeyDown"/>

                <StackPanel x:Name="ConfirmPanel" Margin="0,0,0,12">
                    <Label Content="Confirm Password"/>
                    <PasswordBox x:Name="ConfirmInput" KeyDown="PasswordInput_KeyDown"/>
                </StackPanel>

                <TextBlock x:Name="StatusBlock" Foreground="{StaticResource DangerBrush}"
                           FontSize="12" TextWrapping="Wrap" Margin="0,0,0,16"
                           Visibility="Collapsed"/>

                <Button x:Name="UnlockBtn" Style="{StaticResource SecondaryButton}"
                        Content="Unlock Manually" Height="44" Click="UnlockBtn_Click"/>

                <TextBlock x:Name="LoadingText" Text="Deriving key, please wait..."
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,12,0,0" Visibility="Collapsed"/>

                <TextBlock Text="Local-first encryption. Offline by default."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           Margin="0,14,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>


