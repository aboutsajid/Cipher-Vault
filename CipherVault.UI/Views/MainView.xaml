<Page x:Class="CipherVault.UI.Views.MainView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}"
      Title="Cipher™ Vault">
    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="RootGrid"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.35"/>
                    <DoubleAnimation Storyboard.TargetName="DashboardDeck"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                     From="18" To="0" Duration="0:0:0.45"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Page.Triggers>

    <Grid x:Name="RootGrid" Opacity="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="34" Height="34" CornerRadius="8" Background="{StaticResource SurfaceHighBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <Image Source="/Resources/app_clean.png" Width="24" Height="24" Stretch="Uniform"/>
                    </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Cipher" Style="{StaticResource BrandWordText}" FontSize="15"/>
                                <TextBlock Text="™" Style="{StaticResource BrandTrademarkText}" FontSize="8" Margin="-1,1,0,0"/>
                                <TextBlock Text=" Vault" FontFamily="{StaticResource BrandFontFamily}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <Border Height="1" Width="52" Margin="1,0,0,0" Background="{StaticResource BrandUnderlineBrush}"/>
                        </StackPanel>
                        <TextBlock Text="Local vault" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <TextBox Grid.Column="1" x:Name="SearchBox" Margin="26,0"
                         VerticalAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource PrimaryButton}" Content="Quick Save" Padding="12,6"
                            ToolTip="Ctrl+Shift+S"
                            Command="{Binding NewEntryCommand}"/>
                    <Button Style="{StaticResource PrimaryButton}" Content="New" Padding="12,6" Margin="8,0,0,0"
                            Command="{Binding NewEntryCommand}"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Generator" Padding="12,6" Margin="8,0,0,0"
                            Command="{Binding OpenGeneratorCommand}"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Audit" Padding="12,6" Margin="8,0,0,0"
                            Command="{Binding OpenAuditCommand}"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Browser" Padding="12,6" Margin="8,0,0,0"
                            Command="{Binding OpenBrowserSetupCommand}"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Trust" Padding="12,6" Margin="8,0,0,0"
                            Command="{Binding OpenTrustCommand}"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Settings" Padding="12,6" Margin="8,0,0,0"
                            Command="{Binding OpenSettingsCommand}"/>
                    <Button Style="{StaticResource DangerButton}" Content="Lock" Padding="12,6" Margin="8,0,0,0"
                            Command="{Binding LockCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="232"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Margin="0,0,8,0">
                <StackPanel Margin="12">
                    <TextBlock Text="Folders" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="2,0,0,8"/>

                    <Button Style="{StaticResource SecondaryButton}" Content="All Entries" Margin="0,0,0,6" Click="AllEntries_Click"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Favorites" Margin="0,0,0,6" Click="Favorites_Click"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="{Binding RecycleBinCount, StringFormat=Recycle Bin ({0})}" Margin="0,0,0,8" Click="RecycleBin_Click"/>

                    <Separator Margin="0,6" Background="{StaticResource BorderBrush}"/>

                    <ListBox ItemsSource="{Binding Folders}"
                             SelectedValuePath="Id"
                             SelectedValue="{Binding SelectedFolderId, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Separator Margin="0,8" Background="{StaticResource BorderBrush}"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Import/Export"
                            Command="{Binding OpenImportExportCommand}" ToolTip="Ctrl+Shift+B"/>

                    <TextBlock Text="{Binding StatusText}" Margin="0,10,0,0"
                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding OnboardingSummary}" Margin="0,4,0,0"
                               FontSize="10" Foreground="{StaticResource AccentBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding TrustScoreLabel}" Margin="0,4,0,0"
                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding BackupConfidenceLabel}" Margin="0,4,0,0"
                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding BrowserFlowLabel}" Margin="0,4,0,0"
                               FontSize="10" Foreground="{StaticResource AccentBrush}"
                               TextWrapping="Wrap"/>

                    <Border Margin="0,10,0,0" Padding="10"
                            Background="{StaticResource SurfaceHighBrush}" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="Smart Suggestions" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <ItemsControl ItemsSource="{Binding SmartSuggestions}" Margin="0,6,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Text="{Binding StringFormat=- {0}}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="{Binding BadgeSubtitle}" Margin="0,6,0,0" FontSize="10"
                                       Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding BackupConfidenceLabel}" Margin="0,4,0,0" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding BrowserFlowLabel}" Margin="0,2,0,0" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="12,9" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                            Background="{StaticResource SurfaceHighBrush}">
                        <TextBlock>
                            <Run Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Text="Showing "/>
                            <Run Foreground="{StaticResource AccentBrush}" FontSize="12" FontWeight="SemiBold"
                                 Text="{Binding Entries.Count, Mode=OneWay}"/>
                            <Run Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Text=" entries  -  "/>
                            <Run Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Text="{Binding SecurityHealthLabel, Mode=OneWay}"/>
                        </TextBlock>
                    </Border>

                    <Border x:Name="DashboardDeck" Grid.Row="1" Padding="10,8" Margin="8,8,8,0"
                            Background="{StaticResource SurfaceHighBrush}" CornerRadius="8"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <TranslateTransform Y="18"/>
                        </Border.RenderTransform>
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource MetricCardBorder}" Margin="0,0,6,0">
                                    <StackPanel>
                                        <TextBlock Text="Vault Size" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding TotalEntriesCount}" FontSize="22" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource MetricCardBorder}" Margin="0,0,6,0">
                                    <StackPanel>
                                        <TextBlock Text="Secure Entries" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding SecureEntriesCount}" FontSize="22" FontWeight="Bold"
                                                   Foreground="{StaticResource SuccessBrush}"/>
                                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding SecurityHealthPercent}" Height="6" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource MetricCardBorder}" Margin="0,0,6,0">
                                    <StackPanel>
                                        <TextBlock Text="Security Streak" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding SecurityStreakDays}" FontSize="22" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBrush}"/>
                                        <TextBlock Text="days" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="3" Style="{StaticResource MetricCardBorder}">
                                    <StackPanel>
                                        <TextBlock Text="Badge" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding BadgeTitle}" FontSize="15" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBrush}"/>
                                        <TextBlock Text="{Binding CompletedChallengeCount, StringFormat=Challenges: {0}}"
                                                   FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="7" Padding="8,6">
                                <StackPanel>
                                    <TextBlock Text="{Binding WeeklyChallengeTitle}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding WeeklyChallengeStatus}" FontSize="10" Margin="0,2,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <ListBox Grid.Row="2" ItemsSource="{Binding Entries}" SelectedItem="{Binding SelectedEntry}" Margin="8">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding Username}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1" Text="FAV" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"
                                               Visibility="{Binding Favorite, Converter={StaticResource BoolToVisConverter}}" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding SelectedEntry, Converter={StaticResource NullToVisConverter}}">
                        <TextBlock Text="Entry Details" Style="{StaticResource Heading}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Select an entry from the list" Style="{StaticResource SubHeading}" Margin="0,6,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Margin="20" DataContext="{Binding SelectedEntry}"
                                Visibility="{Binding DataContext.SelectedEntry, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource NotNullToVisConverter}}">
                        <TextBlock Text="{Binding Title}" Style="{StaticResource Heading}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding Url}" Style="{StaticResource SubHeading}" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding DeletedAtUtc, StringFormat=Deleted on {0:g}}" FontSize="10" Foreground="{StaticResource DangerBrush}" Margin="0,0,0,12"
                                   Visibility="{Binding IsDeleted, Converter={StaticResource BoolToVisConverter}}"/>

                        <Label Content="Username"/>
                        <TextBlock Text="{Binding Username}" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,14"/>

                        <Label Content="Password"/>
                        <TextBlock Text="************" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,14"/>

                        <Label Content="Rotation Reminder"/>
                        <TextBlock Text="{Binding DataContext.SelectedEntryPasswordReminderStatus, RelativeSource={RelativeSource AncestorType=Page}}"
                                   Margin="0,0,0,14"
                                   FontSize="11"
                                   Visibility="{Binding DataContext.SelectedEntryPasswordReminderStatus, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource StringToVisConverter}}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsSelectedEntryPasswordReminderWarning, RelativeSource={RelativeSource AncestorType=Page}}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <StackPanel Margin="0,0,0,14">
                            <Label Content="Password History"/>
                            <TextBlock Text="No previous passwords saved."
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,6"
                                       Visibility="{Binding DataContext.HasSelectedEntryPasswordHistory, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource InverseBoolToVisConverter}}"/>
                            <ItemsControl ItemsSource="{Binding DataContext.SelectedEntryPasswordHistory, RelativeSource={RelativeSource AncestorType=Page}}"
                                          Visibility="{Binding DataContext.HasSelectedEntryPasswordHistory, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource BoolToVisConverter}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource SurfaceHighBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding ChangedAtUtc, StringFormat=Changed on {0:g}}"
                                                               FontSize="10"
                                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    <TextBlock Text="************"
                                                               FontSize="12"
                                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Button Style="{StaticResource SecondaryButton}" Content="Copy" Padding="8,4"
                                                            Click="CopyHistoryPassword_Click"/>
                                                    <Button Style="{StaticResource PrimaryButton}" Content="Restore" Padding="8,4" Margin="6,0,0,0"
                                                            Click="RestoreHistoryPassword_Click"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,14"
                                    Visibility="{Binding DataContext.HasTotpForSelectedEntry, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource BoolToVisConverter}}">
                            <Label Content="TOTP (2FA)"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Border Background="{StaticResource SurfaceHighBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10,6">
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"
                                               Text="{Binding DataContext.TotpCode, RelativeSource={RelativeSource AncestorType=Page}}"/>
                                </Border>
                                <Button Style="{StaticResource SecondaryButton}" Content="Copy TOTP" Padding="10,6" Margin="8,0,0,0"
                                        DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}"
                                        Command="{Binding CopyTotpCodeCommand}"/>
                            </StackPanel>
                            <TextBlock FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="{Binding DataContext.TotpCountdownLabel, RelativeSource={RelativeSource AncestorType=Page}}"/>
                        </StackPanel>
                        <Label Content="Notes"/>
                        <TextBlock Text="{Binding Notes}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,0,0,16"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Style="{StaticResource SecondaryButton}" Content="Copy Username" Padding="10,6"
                                    DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}"
                                    Command="{Binding CopyUsernameCommand}"/>
                            <Button Style="{StaticResource PrimaryButton}" Content="Copy Password" Padding="10,6" Margin="8,0,0,0"
                                    DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}"
                                    Command="{Binding CopyPasswordCommand}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Style="{StaticResource SecondaryButton}" Content="Check Breach" Padding="10,6"
                                    DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}"
                                    Command="{Binding CheckSelectedEntryBreachCommand}"/>
                        </StackPanel>

                        <TextBlock Text="{Binding DataContext.SelectedEntryBreachStatus, RelativeSource={RelativeSource AncestorType=Page}}"
                                   FontSize="10" Margin="0,0,0,12" Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding DataContext.SelectedEntryBreachStatus, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource StringToVisConverter}}"/>

                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource SecondaryButton}" Content="Restore" Padding="10,6"
                                    DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}"
                                    Command="{Binding RestoreEntryCommand}"/>
                            <Button Style="{StaticResource SecondaryButton}" Content="Edit" Padding="10,6"
                                    DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}"
                                    Command="{Binding EditEntryCommand}"/>
                            <Button Style="{StaticResource SecondaryButton}" Content="Toggle Favorite" Padding="10,6" Margin="8,0,0,0"
                                    DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}"
                                    Command="{Binding ToggleFavoriteCommand}"/>
                            <Button Style="{StaticResource DangerButton}" Content="{Binding DeleteActionLabel}" Padding="10,6" Margin="8,0,0,0"
                                    DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}"
                                    Click="DeleteEntry_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>





