<Page x:Class="CipherVault.UI.Views.AuditView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}" Title="Security Audit">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20,16">
            <StackPanel>
                <Button Style="{StaticResource SecondaryButton}" Content="Back" Click="Back_Click"
                        HorizontalAlignment="Left" Padding="12,6" Margin="0,0,0,12"/>

                <TextBlock Text="Security Audit" Style="{StaticResource Heading}" Margin="0,0,0,8"/>
                <TextBlock Text="Check your passwords for weaknesses, reuse, breach exposure, and duplicate accounts." Style="{StaticResource SubHeading}" Margin="0,0,0,24"/>

                <StackPanel Margin="0,0,0,16">
                    <WrapPanel>
                        <Button Style="{StaticResource PrimaryButton}" Content="Run Full Scan"
                                Command="{Binding RunFullScanCommand}" HorizontalAlignment="Left" Padding="20,10" Margin="0,0,10,8"/>
                        <Button Style="{StaticResource SecondaryButton}" Content="Run Audit"
                                Command="{Binding RunAuditCommand}" HorizontalAlignment="Left" Padding="20,10" Margin="0,0,10,8"/>
                        <Button Style="{StaticResource SecondaryButton}" Content="Run Breach Scan"
                                Command="{Binding RunBreachScanCommand}" HorizontalAlignment="Left" Padding="20,10" Margin="0,0,10,8"/>
                        <Button Style="{StaticResource SecondaryButton}" Content="Cancel Breach Scan"
                                Command="{Binding CancelBreachScanCommand}" HorizontalAlignment="Left" Padding="20,10" Margin="0,0,10,8"/>
                        <Button Style="{StaticResource SecondaryButton}" Content="Scan Duplicates"
                                Command="{Binding RunDuplicateScanCommand}" HorizontalAlignment="Left" Padding="20,10" Margin="0,0,10,8"/>
                    </WrapPanel>

                    <TextBlock Text="{Binding ScanStatusLabel}" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,0,10" TextWrapping="Wrap"/>

                    <WrapPanel>
                        <Button Style="{StaticResource SecondaryButton}" Content="Open Next"
                                Command="{Binding OpenActiveRemediationItemCommand}" HorizontalAlignment="Left" Padding="14,8" Margin="0,0,10,0"/>
                        <Button Style="{StaticResource SecondaryButton}" Content="Mark Done"
                                Command="{Binding MarkActiveRemediationDoneCommand}" HorizontalAlignment="Left" Padding="14,8" Margin="0,0,10,0"/>
                        <Button Style="{StaticResource SecondaryButton}" Content="Skip"
                                Command="{Binding SkipActiveRemediationItemCommand}" HorizontalAlignment="Left" Padding="14,8" Margin="0,0,10,0"/>
                        <Button Style="{StaticResource SecondaryButton}" Content="Reset Queue"
                                Command="{Binding ResetRemediationQueueCommand}" HorizontalAlignment="Left" Padding="14,8" Margin="0,0,10,0"/>
                        <Button Style="{StaticResource SecondaryButton}" Content="{Binding UndoRemediationQueueActionLabel}"
                                Command="{Binding UndoRemediationQueueActionCommand}" HorizontalAlignment="Left" Padding="14,8" Margin="0,0,10,0"/>
                        <Button Style="{StaticResource PrimaryButton}" Content="Auto Secure"
                                Command="{Binding AutoSecureActiveRemediationItemCommand}" HorizontalAlignment="Left" Padding="14,8"/>
                    </WrapPanel>
                </StackPanel>

                <TextBlock Text="Fix Queue" Style="{StaticResource Heading}" Margin="0,0,0,6"/>
                <TextBlock Text="{Binding RemediationQueueSummary}" Foreground="{StaticResource AccentBrush}"
                           FontSize="13" Margin="0,0,0,2" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding QueueGuidance}" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" Margin="0,0,0,4" TextWrapping="Wrap"/>
                
                <TextBlock Text="{Binding ActiveRemediationLabel}" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" Margin="0,0,0,6" TextWrapping="Wrap"/>
                <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource SuccessBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="10" Margin="0,0,0,10"
                        Visibility="{Binding QueueCompletionMessage, Converter={StaticResource StringToVisConverter}}">
                    <TextBlock Text="{Binding QueueCompletionMessage}" Foreground="{StaticResource SuccessBrush}" FontSize="12" FontWeight="SemiBold"/>
                </Border>
                <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="10" Margin="0,0,0,10"
                        Visibility="{Binding HasDismissedRemediationItems, Converter={StaticResource BoolToVisConverter}}">
                    <StackPanel>
                        <TextBlock Text="Dismissed Items" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding DismissedRemediationSummary}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,2,0,8"/>
                        <ItemsControl ItemsSource="{Binding DismissedRemediationItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding EntryTitle}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding RiskLabel}" Foreground="{StaticResource DangerBrush}" FontSize="10"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Content="Restore"
                                                Padding="10,4" Margin="8,0,0,0"
                                                Command="{Binding DataContext.RestoreDismissedRemediationItemCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding EntryId}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding RemediationQueue}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Padding="12" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding EntryTitle}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding RiskLabel}" Foreground="{StaticResource DangerBrush}" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Content="Edit"
                                            Padding="10,4" Margin="8,0,0,0"
                                            Command="{Binding DataContext.OpenEntryEditorCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding EntryId}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Separator Margin="0,8,0,12" Background="{StaticResource BorderBrush}"/>
                <TextBlock Text="{Binding Summary}" Foreground="{StaticResource AccentBrush}"
                           FontSize="14" Margin="0,0,0,12"/>

                <ItemsControl ItemsSource="{Binding Results}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,8">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding EntryTitle}" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" FontSize="14"/>
                                        <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Content="Edit Entry"
                                                Padding="10,4" Margin="10,0,0,0"
                                                Command="{Binding DataContext.OpenEntryEditorCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding EntryId}"/>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding Issues}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" Foreground="{StaticResource DangerBrush}"
                                                           FontSize="12" Margin="0,4,0,0"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Separator Margin="0,8,0,12" Background="{StaticResource BorderBrush}"/>
                <TextBlock Text="Breach Scan" Style="{StaticResource Heading}" Margin="0,0,0,8"/>
                <TextBlock Text="{Binding BreachSummary}" Foreground="{StaticResource AccentBrush}"
                           FontSize="13" Margin="0,0,0,6" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding BreachProgressLabel}" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" Margin="0,0,0,4" TextWrapping="Wrap"/>
                <ProgressBar Minimum="0" Maximum="{Binding BreachProgressMaximum}" Value="{Binding BreachProgressValue}" Height="8" Margin="0,0,0,10"
                             Visibility="{Binding IsBreachScanRunning, Converter={StaticResource BoolToVisConverter}}"/>

                <ItemsControl ItemsSource="{Binding BreachResults}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,8">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding EntryTitle}" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" FontSize="14"/>
                                        <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Content="Edit Entry"
                                                Padding="10,4" Margin="10,0,0,0"
                                                Command="{Binding DataContext.OpenEntryEditorCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding EntryId}"/>
                                    </Grid>
                                    <TextBlock Text="{Binding StatusLabel}" Foreground="{StaticResource DangerBrush}"
                                               FontSize="12" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Separator Margin="0,8,0,12" Background="{StaticResource BorderBrush}"/>
                <TextBlock Text="Duplicate Accounts" Style="{StaticResource Heading}" Margin="0,0,0,8"/>
                <TextBlock Text="{Binding DuplicateSummary}" Foreground="{StaticResource AccentBrush}"
                           FontSize="13" Margin="0,0,0,10" TextWrapping="Wrap"/>

                <ItemsControl ItemsSource="{Binding DuplicateGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14">
                                        <Run Text="{Binding Username}"/>
                                        <Run Text=" @ "/>
                                        <Run Text="{Binding Site}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Entries.Count, StringFormat={}{0} entries share this account}"
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,6"/>

                                    <ItemsControl ItemsSource="{Binding Entries}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding Title}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="{Binding Url}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="FAV" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"
                                                               Visibility="{Binding Favorite, Converter={StaticResource BoolToVisConverter}}" VerticalAlignment="Center" Margin="8,0,6,0"/>
                                                    <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Content="Edit"
                                                            Padding="10,4"
                                                            Command="{Binding DataContext.OpenEntryEditorCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding EntryId}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Button Style="{StaticResource SecondaryButton}" Content="Merge Group"
                                            Margin="0,8,0,0" HorizontalAlignment="Left" Padding="12,6"
                                            Command="{Binding DataContext.MergeDuplicateGroupCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>

