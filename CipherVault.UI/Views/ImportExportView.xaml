<Page x:Class="CipherVault.UI.Views.ImportExportView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}" Title="Import / Export">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20,16">
            <StackPanel>
                <Button Style="{StaticResource SecondaryButton}" Content="Back" Click="Back_Click"
                        HorizontalAlignment="Left" Padding="12,6" Margin="0,0,0,12"/>

                <TextBlock Text="Import / Export" Style="{StaticResource Heading}" Margin="0,0,0,24"/>

                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Export Vault" FontWeight="SemiBold" FontSize="15"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                        <Label Content="Export Password"/>
                        <PasswordBox x:Name="ExportPwBox" Margin="0,0,0,12"
                                     PasswordChanged="ExportPwBox_PasswordChanged"/>

                        <Label Content="Save Location"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding ExportFilePath}" IsReadOnly="True"/>
                            <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Content="Browse"
                                    Command="{Binding BrowseExportCommand}" Margin="8,0,0,0" Padding="12,8"/>
                        </Grid>

                        <Button Style="{StaticResource PrimaryButton}" Content="Export"
                                Command="{Binding ExportCommand}" HorizontalAlignment="Left" Padding="20,10"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Import Vault / CSV" FontWeight="SemiBold" FontSize="15"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                        <Border Background="{StaticResource DangerBrush}" CornerRadius="6" Padding="12"
                                Margin="0,0,0,12"
                                Visibility="{Binding ShowCsvWarning, Converter={StaticResource BoolToVisConverter}}">
                            <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="12">
                                WARNING: CSV files are not encrypted. Your passwords are exposed.
                                After import, please delete the CSV file immediately.
                            </TextBlock>
                        </Border>

                        <Label Content="Backup Password (for .cipherpw-backup files)"/>
                        <PasswordBox x:Name="ImportPwBox" Margin="0,0,0,12"
                                     PasswordChanged="ImportPwBox_PasswordChanged"/>

                        <Label Content="File to Import"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding ImportFilePath}" IsReadOnly="True"/>
                            <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Content="Browse"
                                    Command="{Binding BrowseImportCommand}" Margin="8,0,0,0" Padding="12,8"/>
                        </Grid>

                        <Button Style="{StaticResource PrimaryButton}" Content="Import"
                                Command="{Binding ImportCommand}" HorizontalAlignment="Left" Padding="20,10"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" FontSize="13"
                           Foreground="{StaticResource AccentBrush}"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>


