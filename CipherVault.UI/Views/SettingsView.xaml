<Page x:Class="CipherVault.UI.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}" Title="Settings">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20,16">
            <StackPanel DataContext="{Binding Settings}">
                <Button Style="{StaticResource SecondaryButton}" Content="Back" Click="Back_Click"
                        HorizontalAlignment="Left" Padding="12,6" Margin="0,0,0,12"
                        DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}"/>

                <TextBlock Text="Settings" Style="{StaticResource Heading}" Margin="0,0,0,24"
                           DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}"/>

                <TextBlock Text="Clipboard Auto-Clear"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           Margin="0,0,0,2"/>
                <TextBlock Text="{Binding ClipboardClearSeconds, StringFormat={}{0}s}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>
                <Slider Value="{Binding ClipboardClearSeconds}" Minimum="5" Maximum="120"
                        TickFrequency="5" IsSnapToTickEnabled="True" Margin="0,0,0,20"/>

                <TextBlock Text="Auto-Lock Timer"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           Margin="0,0,0,2"/>
                <TextBlock Text="{Binding AutoLockMinutes, StringFormat={}{0} minute(s)}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>
                <Slider Value="{Binding AutoLockMinutes}" Minimum="1" Maximum="60"
                        TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,0,0,20"/>

                <TextBlock Text="Recycle Bin Auto-Purge"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           Margin="0,0,0,2"/>
                <TextBlock Text="{Binding RecycleBinRetentionDays, StringFormat={}{0} day(s)}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>
                <Slider Value="{Binding RecycleBinRetentionDays}" Minimum="1" Maximum="365"
                        TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,0,0,20"/>

                <CheckBox Content="Lock on minimize" IsChecked="{Binding LockOnMinimize}" Margin="0,0,0,16"/>

                <CheckBox Content="Allow breach check (opt-in, requires network)"
                          IsChecked="{Binding AllowBreachCheck}" Margin="0,0,0,24"/>

                <CheckBox Content="Start CipherVault when Windows starts"
                          IsChecked="{Binding StartWithWindows}" Margin="0,0,0,16"/>

                <CheckBox Content="Enable Windows Hello unlock (fingerprint/face/PIN)"
                          IsChecked="{Binding WindowsHelloEnabled}" Margin="0,0,0,4"/>
                <TextBlock Text="Use your biometric/PIN to unlock quickly after one password unlock."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11"
                           Margin="0,0,0,20"
                           TextWrapping="Wrap"/>

                <Label Content="Theme Mode"/>
                <ComboBox SelectedValue="{Binding Theme}" SelectedValuePath="Tag" Margin="0,0,0,24"
                          Background="{StaticResource SurfaceHighBrush}"
                          Foreground="{StaticResource TextPrimaryBrush}">
                    <ComboBoxItem Content="Light" Tag="Light"/>
                    <ComboBoxItem Content="System Sync" Tag="System"/>
                </ComboBox>

                <CheckBox Content="Silent browser capture (auto-save without popup)"
                          IsChecked="{Binding BrowserCaptureSilentMode}" Margin="0,0,0,12"/>

                <Label Content="Always auto-save domains (comma separated)"/>
                <TextBox Text="{Binding BrowserCaptureAutoSaveDomains, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,24"
                         Background="{StaticResource SurfaceHighBrush}"
                         Foreground="{StaticResource TextPrimaryBrush}"/>

                <StackPanel Orientation="Horizontal"
                            DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}">
                    <Button Style="{StaticResource PrimaryButton}" Content="Save Settings"
                            Command="{Binding SaveCommand}" Padding="20,10"/>
                </StackPanel>

                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource SuccessBrush}" FontSize="13" Margin="0,16,0,0"
                           DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>



