<Page x:Class="CipherVault.UI.Views.PasswordGeneratorView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}" Title="Password Generator">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20,16">
        <StackPanel>
            <Button Style="{StaticResource SecondaryButton}" Content="Back" Click="Back_Click"
                    HorizontalAlignment="Left" Padding="12,6" Margin="0,0,0,12"/>

            <TextBlock Text="Password Generator" Style="{StaticResource Heading}" Margin="0,0,0,24"/>

            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{Binding GeneratedPassword}" FontFamily="Consolas" FontSize="16"
                               Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <Label Content="{Binding Length, StringFormat='Length: {0}'}"/>
            <Slider Value="{Binding Length}" Minimum="8" Maximum="64" TickFrequency="1"
                    IsSnapToTickEnabled="True" Margin="0,0,0,16"/>

            <CheckBox Content="Uppercase (A-Z)" IsChecked="{Binding IncludeUpper}" Margin="0,0,0,8"/>
            <CheckBox Content="Lowercase (a-z)" IsChecked="{Binding IncludeLower}" Margin="0,0,0,8"/>
            <CheckBox Content="Numbers (0-9)" IsChecked="{Binding IncludeNumbers}" Margin="0,0,0,8"/>
            <CheckBox Content="Symbols (!@#$...)" IsChecked="{Binding IncludeSymbols}" Margin="0,0,0,8"/>
            <CheckBox Content="Exclude similar characters (Il1O0)" IsChecked="{Binding ExcludeSimilar}" Margin="0,0,0,24"/>

            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource PrimaryButton}" Content="Generate"
                        Command="{Binding GenerateCommand}" Padding="20,10"/>
                <Button Style="{StaticResource SecondaryButton}" Content="Copy" Margin="12,0,0,0"
                        Command="{Binding CopyCommand}" Padding="20,10"/>
            </StackPanel>
        </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>


