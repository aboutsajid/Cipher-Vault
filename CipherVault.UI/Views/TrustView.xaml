<Page x:Class="CipherVault.UI.Views.TrustView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}"
      Title="Trust and Transparency">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20,16">
            <StackPanel>
                <Button Style="{StaticResource SecondaryButton}" Content="Back" Click="Back_Click"
                        HorizontalAlignment="Left" Padding="12,6" Margin="0,0,0,12"/>

                <TextBlock Text="Trust and Transparency" Style="{StaticResource Heading}" Margin="0,0,0,6"/>
                <TextBlock Text="Everything below is visible so users can verify security decisions before trusting Cipher™ Vault."
                           Style="{StaticResource SubHeading}" Margin="0,0,0,18" TextWrapping="Wrap"/>
                <Border Background="{StaticResource DangerBrush}" CornerRadius="8" Padding="10" Margin="0,0,0,12"
                        Visibility="{Binding IsMandatory, Converter={StaticResource BoolToVisConverter}}">
                    <TextBlock Text="Mandatory setup: complete and save the checklist to continue."
                               Foreground="White" FontSize="12"/>
                </Border>

                <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Transparency Highlights" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="- Local-first storage: secrets stay on your device." Margin="0,0,0,3"/>
                        <TextBlock Text="- Encryption at rest: Argon2 + AES-GCM." Margin="0,0,0,3"/>
                        <TextBlock Text="- Browser capture asks for save approval by default (optional silent/auto-save available)." Margin="0,0,0,3"/>
                        <TextBlock Text="- No hidden telemetry by default." Margin="0,0,0,3"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Security Readiness Score" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TrustScoreLabel}" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>
                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding TrustScorePercent, Mode=OneWay}" Height="10" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding SecurityStreakDays, StringFormat='Security streak: {0} day(s)'}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding CompletedChallengeCount, StringFormat='Challenges completed: {0}'}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding GamifiedStatus}" Margin="0,0,0,6"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding ImprovementHint}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                        <TextBlock Text="10/10 ready"
                                   Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold"
                                   Visibility="{Binding IsTenOutOfTenReady, Converter={StaticResource BoolToVisConverter}}"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Onboarding Security Checklist" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>

                        <CheckBox Content="I have set a strong master password (12+ chars)." IsChecked="{Binding ConfirmMasterPassword}" Margin="0,0,0,8"/>
                        <CheckBox Content="I created and verified an encrypted backup." IsChecked="{Binding ConfirmBackup}" Margin="0,0,0,8"/>
                        <CheckBox Content="I reviewed transparency and browser capture permissions." IsChecked="{Binding ConfirmTransparency}" Margin="0,0,0,12"/>

                        <TextBlock Text="{Binding AutoLockStatus}" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding ClipboardStatus}" Margin="0,0,0,12"/>

                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource SecondaryButton}" Content="Apply Recommended Security"
                                    Command="{Binding ApplyRecommendedCommand}" Padding="14,8"/>
                            <Button Style="{StaticResource PrimaryButton}" Content="Save Checklist" Margin="10,0,0,0"
                                    Command="{Binding SaveCommand}" Padding="18,8"/>
                        </StackPanel>

                        <TextBlock Text="{Binding ChecklistSummary}" Margin="0,12,0,0" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="{Binding StatusMessage}" Margin="0,6,0,0"
                                   Foreground="{StaticResource SuccessBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>


