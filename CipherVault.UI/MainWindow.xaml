<Window x:Class="CipherVault.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cipher™ Vault" Height="680" Width="1050" MinHeight="500" MinWidth="700"
        Icon="/Resources/app.ico"
        Background="{DynamicResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="34"/>
        </Grid.RowDefinitions>

        <Frame Grid.Row="0" x:Name="MainFrame" NavigationUIVisibility="Hidden"/>

        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="11"
                       Text="(c) 2026 Cipher™ Vault  |  Credits: aboutsajid@gmail.com"/>
        </Border>
    </Grid>
</Window>



